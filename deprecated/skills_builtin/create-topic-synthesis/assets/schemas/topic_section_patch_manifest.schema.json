{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topic Synthesis Section Patch Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "schema_version",
    "operation",
    "language",
    "sidecars",
    "base",
    "patch"
  ],
  "properties": {
    "schema_id": { "const": "synthesis.topic_section_patch_manifest" },
    "schema_version": { "type": "string" },
    "operation": { "const": "update_patch" },
    "topic_id": { "type": "string" },
    "language": { "type": "string", "minLength": 1 },
    "sidecars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topic_interest_metadata",
        "concept_cards_proposal",
        "topic_graph_relation_proposals"
      ],
      "properties": {
        "topic_interest_metadata": {
          "type": "object",
          "required": ["path", "hash", "content_type", "schema_id"],
          "properties": {
            "path": {
              "const": "result/sidecars/topic-interest-metadata.json"
            },
            "hash": { "type": "string", "minLength": 1 },
            "content_type": { "const": "json" },
            "schema_id": { "const": "topic_interest_metadata.v1" }
          }
        },
        "concept_cards_proposal": {
          "type": "object",
          "required": ["path", "hash", "content_type", "schema_id"],
          "properties": {
            "path": {
              "const": "result/sidecars/concept-cards-proposal.json"
            },
            "hash": { "type": "string", "minLength": 1 },
            "content_type": { "const": "json" },
            "schema_id": { "const": "synthesis.concept_cards_proposal" }
          }
        },
        "topic_graph_relation_proposals": {
          "type": "object",
          "required": ["path", "hash", "content_type", "schema_id"],
          "properties": {
            "path": {
              "const": "result/sidecars/topic-graph-relation-proposals.json"
            },
            "hash": { "type": "string", "minLength": 1 },
            "content_type": { "const": "json" },
            "schema_id": {
              "const": "synthesis.topic_graph_relation_proposals"
            }
          }
        }
      }
    },
    "base": {
      "type": "object",
      "required": [
        "current_manifest_hash",
        "current_artifact_hash",
        "read_section_hashes",
        "replace_section_hashes"
      ],
      "properties": {
        "current_manifest_hash": { "type": "string" },
        "current_artifact_hash": { "type": "string" },
        "read_section_hashes": { "type": "object" },
        "replace_section_hashes": { "type": "object" }
      }
    },
    "patch": {
      "type": "object",
      "required": [
        "mode",
        "changed_sections",
        "unchanged_section_policy",
        "sections"
      ],
      "properties": {
        "mode": { "const": "section_replace" },
        "changed_sections": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unchanged_section_policy": { "const": "inherit_current" },
        "sections": { "type": "object" }
      }
    }
  },
  "not": {
    "anyOf": [{ "required": ["markdown"] }, { "required": ["markdown_path"] }]
  }
}
