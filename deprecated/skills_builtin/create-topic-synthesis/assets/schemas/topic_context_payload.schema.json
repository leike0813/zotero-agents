{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.create_topic_context_payload",
  "type": "object",
  "required": ["topic_title", "duplicate_status"],
  "properties": {
    "topic_title": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "definition": { "type": "string" },
    "scope_include": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "scope_exclude": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "duplicate_status": {
      "enum": [
        "none",
        "possible_duplicate",
        "duplicate",
        "needs_user_confirmation"
      ]
    },
    "duplicate_candidate_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "duplicate_reason": { "type": "string" },
    "diagnostics": { "type": "array", "default": [] }
  },
  "additionalProperties": false
}
