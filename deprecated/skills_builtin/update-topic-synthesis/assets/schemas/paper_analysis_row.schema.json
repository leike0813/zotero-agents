{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topic Synthesis Paper Triage Row",
  "type": "object",
  "additionalProperties": false,
  "required": ["paper_ref", "topic_relevance", "paper_quality", "core_digest"],
  "properties": {
    "paper_ref": { "type": "string", "minLength": 1 },
    "topic_relevance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reason"],
      "properties": {
        "level": { "enum": ["core", "related", "peripheral", "excluded"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "paper_quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reason"],
      "properties": {
        "level": { "enum": ["high", "medium", "low", "unknown"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "core_digest": { "type": "string", "minLength": 1 },
    "caveats": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
