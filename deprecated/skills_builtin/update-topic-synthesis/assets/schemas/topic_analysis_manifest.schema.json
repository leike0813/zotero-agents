{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topic Synthesis Analysis Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "schema_version",
    "operation",
    "language",
    "sidecars",
    "sections"
  ],
  "properties": {
    "schema_id": { "const": "synthesis.topic_analysis_manifest" },
    "schema_version": { "type": "string" },
    "operation": { "enum": ["create", "update_full"] },
    "topic_id": { "type": "string" },
    "language": { "type": "string", "minLength": 1 },
    "sidecars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topic_interest_metadata",
        "concept_cards_proposal",
        "topic_graph_relation_proposals"
      ],
      "properties": {
        "topic_interest_metadata": {
          "type": "object",
          "required": ["path", "hash", "content_type", "schema_id"],
          "properties": {
            "path": {
              "const": "result/sidecars/topic-interest-metadata.json"
            },
            "hash": { "type": "string", "minLength": 1 },
            "content_type": { "const": "json" },
            "schema_id": { "const": "topic_interest_metadata.v1" }
          }
        },
        "concept_cards_proposal": {
          "type": "object",
          "required": ["path", "hash", "content_type", "schema_id"],
          "properties": {
            "path": {
              "const": "result/sidecars/concept-cards-proposal.json"
            },
            "hash": { "type": "string", "minLength": 1 },
            "content_type": { "const": "json" },
            "schema_id": { "const": "synthesis.concept_cards_proposal" }
          }
        },
        "topic_graph_relation_proposals": {
          "type": "object",
          "required": ["path", "hash", "content_type", "schema_id"],
          "properties": {
            "path": {
              "const": "result/sidecars/topic-graph-relation-proposals.json"
            },
            "hash": { "type": "string", "minLength": 1 },
            "content_type": { "const": "json" },
            "schema_id": {
              "const": "synthesis.topic_graph_relation_proposals"
            }
          }
        }
      }
    },
    "sections": {
      "type": "object",
      "required": [
        "topic",
        "summary",
        "positioning",
        "taxonomy",
        "claims",
        "improvement_dimension_summary",
        "improvement_dimensions",
        "timeline_events",
        "paper_evidence",
        "external_literature_analysis",
        "debates",
        "coverage",
        "gaps",
        "review_outline",
        "statistics",
        "synthesis_report",
        "evidence_map",
        "source_artifacts",
        "diagnostics"
      ],
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["path", "hash", "content_type"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "hash": { "type": "string", "minLength": 1 },
            "content_type": { "const": "json" }
          }
        }
      }
    }
  },
  "not": {
    "anyOf": [{ "required": ["markdown"] }, { "required": ["markdown_path"] }]
  }
}
