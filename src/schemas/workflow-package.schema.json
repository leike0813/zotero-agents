{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow-package.schema.json",
  "title": "WorkflowPackageManifest",
  "type": "object",
  "required": ["id", "version", "workflows"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "i18n": {
      "type": "object",
      "properties": {
        "defaultLocale": {
          "type": "string",
          "minLength": 1
        },
        "locales": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
