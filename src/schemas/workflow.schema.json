{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow.schema.json",
  "title": "WorkflowManifest",
  "type": "object",
  "required": ["id", "label", "provider", "hooks"],
  "properties": {
    "id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "label": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "provider": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "version": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "display": {
      "$ref": "#/$defs/workflowDisplaySpec"
    },
    "taskNameTemplate": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "i18n": {
      "$ref": "#/$defs/workflowI18nSpec"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/parameterSchema"
      }
    },
    "inputs": {
      "$ref": "#/$defs/inputsSpec"
    },
    "validateSelection": {
      "$ref": "#/$defs/validateSelectionSpec"
    },
    "trigger": {
      "$ref": "#/$defs/triggerSpec"
    },
    "execution": {
      "$ref": "#/$defs/executionSpec"
    },
    "result": {
      "$ref": "#/$defs/resultSpec"
    },
    "request": {
      "$ref": "#/$defs/requestSpec"
    },
    "hooks": {
      "$ref": "#/$defs/hooksSpec"
    },
    "backend": false,
    "defaults": false
  },
  "allOf": [
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "request": {
                "type": "object",
                "properties": {
                  "kind": {
                    "const": "skillrunner.job.v1"
                  }
                },
                "required": ["kind"]
              }
            },
            "required": ["request"]
          },
          {
            "not": {
              "properties": {
                "hooks": {
                  "type": "object",
                  "properties": {
                    "buildRequest": {}
                  },
                  "required": ["buildRequest"]
                }
              },
              "required": ["hooks"]
            }
          }
        ]
      },
      "then": {
        "properties": {
          "request": {
            "type": "object",
            "properties": {
              "create": {
                "$ref": "#/$defs/requestCreateSpec"
              }
            },
            "required": ["create"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "skillrunner.sequence.v1"
              }
            },
            "required": ["kind"]
          }
        },
        "required": ["request"]
      },
      "then": {
        "properties": {
          "provider": {
            "enum": ["acp", "skillrunner"]
          },
          "request": {
            "type": "object",
            "properties": {
              "sequence": {
                "$ref": "#/$defs/requestSequenceSpec"
              }
            }
          }
        },
        "anyOf": [
          {
            "properties": {
              "request": {
                "type": "object",
                "properties": {
                  "sequence": {}
                },
                "required": ["sequence"]
              }
            },
            "required": ["request"]
          },
          {
            "properties": {
              "hooks": {
                "type": "object",
                "properties": {
                  "buildRequest": {}
                },
                "required": ["buildRequest"]
              }
            },
            "required": ["hooks"]
          }
        ],
        "required": ["provider"]
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "workflowI18nSpec": {
      "type": "object",
      "properties": {
        "defaultLocale": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "messages": {
          "$ref": "#/$defs/workflowI18nMessages"
        }
      },
      "additionalProperties": false
    },
    "workflowI18nMessages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "workflowDisplaySpec": {
      "type": "object",
      "properties": {
        "core": {
          "type": "boolean"
        },
        "emoji": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16
        }
      },
      "additionalProperties": false
    },
    "parameterSchema": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean"]
        },
        "visible_if": {
          "$ref": "#/$defs/parameterVisibleIf"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "default": {},
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": {}
        },
        "allowCustom": {
          "type": "boolean"
        },
        "optionsSource": {
          "$ref": "#/$defs/parameterOptionsSource"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "required": ["min", "max"],
            "properties": {
              "min": {
                "type": "number"
              },
              "max": {
                "type": "number"
              }
            }
          },
          "then": {
            "properties": {
              "min": {
                "type": "number",
                "maximum": {
                  "$data": "1/max"
                }
              }
            }
          }
        }
      ],
      "additionalProperties": true
    },
    "parameterVisibleIf": {
      "type": "object",
      "required": ["parameter", "equals"],
      "properties": {
        "parameter": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "equals": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "parameterOptionsSource": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "library": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["current", "user"]
            },
            {
              "type": "number"
            }
          ]
        },
        "includeEmpty": {
          "type": "boolean"
        },
        "valueFormat": {
          "type": "string"
        },
        "labelFormat": {
          "type": "string"
        },
        "allowStale": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "hooksSpec": {
      "type": "object",
      "required": ["applyResult"],
      "properties": {
        "buildRequest": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "normalizeSettings": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "applyResult": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "countRule": {
      "type": "object",
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0
        },
        "max": {
          "type": "number",
          "minimum": 0
        },
        "exact": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "validateSelectionSpec": {
      "type": "object",
      "properties": {
        "require": {
          "type": "object",
          "properties": {
            "counts": {
              "type": "object",
              "properties": {
                "parents": { "$ref": "#/$defs/countRule" },
                "attachments": { "$ref": "#/$defs/countRule" },
                "notes": { "$ref": "#/$defs/countRule" },
                "children": { "$ref": "#/$defs/countRule" },
                "total": { "$ref": "#/$defs/countRule" }
              },
              "additionalProperties": false
            },
            "allowMixed": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "select": {
          "type": "object",
          "properties": {
            "policy": {
              "type": "string",
              "enum": [
                "input-unit",
                "literature-source",
                "pdf-attachment",
                "selected-parent",
                "generated-note-candidates",
                "digest-representative-image"
              ]
            },
            "unit": {
              "type": "string",
              "enum": ["attachment", "parent", "note", "workflow"]
            }
          },
          "additionalProperties": false
        },
        "exclude": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "required": ["kind", "noteKinds"],
                "properties": {
                  "kind": {
                    "const": "generated-notes-all"
                  },
                  "noteKinds": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "enum": [
                        "digest",
                        "references",
                        "citation-analysis",
                        "conversation-note",
                        "custom"
                      ]
                    }
                  }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["kind", "target"],
                "properties": {
                  "kind": {
                    "const": "artifact-exists"
                  },
                  "target": {
                    "type": "string",
                    "enum": [
                      "deep-reading-html",
                      "translator-markdown",
                      "mineru-markdown"
                    ]
                  },
                  "parameter": {
                    "$ref": "#/$defs/nonEmptyString"
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "derive": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["exportCandidates", "digestRepresentativeImageTarget"]
          }
        }
      },
      "additionalProperties": false
    },
    "inputsSpec": {
      "type": "object",
      "required": ["unit"],
      "properties": {
        "unit": {
          "type": "string",
          "enum": ["attachment", "parent", "note", "workflow"]
        },
        "accepts": {
          "type": "object",
          "properties": {
            "mime": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "per_parent": {
          "type": "object",
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "triggerSpec": {
      "type": "object",
      "properties": {
        "requiresSelection": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "executionSpec": {
      "type": "object",
      "properties": {
        "mcp": {
          "type": "object",
          "properties": {
            "requiredTools": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "zoteroHostAccess": {
          "type": "object",
          "properties": {
            "required": {
              "type": "boolean"
            },
            "allowWriteApprovalBypass": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "poll_interval_ms": {
          "type": "number"
        },
        "timeout_ms": {
          "type": "number"
        },
        "feedback": {
          "$ref": "#/$defs/executionFeedbackSpec"
        }
      },
      "additionalProperties": false
    },
    "executionFeedbackSpec": {
      "type": "object",
      "properties": {
        "showNotifications": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "resultSpec": {
      "type": "object",
      "properties": {
        "fetch": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["bundle", "result"]
            }
          },
          "additionalProperties": false
        },
        "expects": {
          "type": "object",
          "properties": {
            "result_json": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "final_step_id": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "requestSpec": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "create": {
          "$ref": "#/$defs/requestCreateSpec"
        },
        "input": {
          "$ref": "#/$defs/requestInputSpec"
        },
        "poll": {
          "$ref": "#/$defs/requestPollSpec"
        },
        "sequence": {
          "$ref": "#/$defs/requestSequenceSpec"
        },
        "result": false
      },
      "additionalProperties": true
    },
    "requestCreateSpec": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "skill_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "mode": {
          "type": "string",
          "enum": ["auto", "interactive"]
        },
        "skill_source": {
          "type": "string",
          "enum": ["local-package", "installed"]
        },
        "engine": false,
        "parameter": false,
        "model": false,
        "runtime_options": false
      },
      "additionalProperties": true
    },
    "requestInputSpec": {
      "type": "object",
      "properties": {
        "upload": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/requestUploadFileSpec"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "requestUploadFileSpec": {
      "type": "object",
      "required": ["key", "from"],
      "properties": {
        "key": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "Field name written to request.input.<key> for uploaded file relative path."
        },
        "from": {
          "type": "string",
          "enum": ["selected.markdown", "selected.pdf", "selected.source"]
        }
      },
      "additionalProperties": false
    },
    "requestSequenceSpec": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/requestSequenceStepSpec"
          }
        }
      },
      "additionalProperties": false
    },
    "requestSequenceStepSpec": {
      "type": "object",
      "required": ["id", "skill_id", "mode"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "skill_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "mode": {
          "type": "string",
          "enum": ["auto", "interactive"]
        },
        "input": {
          "type": "object",
          "additionalProperties": true
        },
        "parameter": {
          "type": "object",
          "additionalProperties": true
        },
        "fetch_type": {
          "type": "string",
          "enum": ["bundle", "result"]
        },
        "workspace": {
          "type": "string",
          "enum": ["new", "reuse-workflow"]
        },
        "apply_result": {
          "$ref": "#/$defs/requestSequenceStepApplySpec"
        },
        "handoff": {
          "$ref": "#/$defs/requestSequenceHandoffSpec"
        },
        "short_circuit": {
          "$ref": "#/$defs/requestSequenceShortCircuitSpec"
        },
        "include_if": {
          "$ref": "#/$defs/requestSequenceStepIncludeIfSpec"
        }
      },
      "additionalProperties": false
    },
    "requestSequenceStepIncludeIfSpec": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "parameter", "equals"],
          "properties": {
            "kind": {
              "const": "parameter"
            },
            "parameter": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "equals": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "condition"],
          "properties": {
            "kind": {
              "const": "runtime"
            },
            "condition": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "requestSequenceShortCircuitSpec": {
      "type": "object",
      "required": ["when", "result"],
      "properties": {
        "when": {
          "type": "object",
          "required": ["path", "equals"],
          "properties": {
            "path": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "equals": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "result": {
          "type": "string",
          "enum": ["step_output"]
        }
      },
      "additionalProperties": false
    },
    "requestSequenceStepApplySpec": {
      "type": "object",
      "properties": {
        "workflow_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "on_failure": {
          "type": "string",
          "enum": ["continue", "fail_sequence"]
        }
      },
      "additionalProperties": false
    },
    "requestSequenceHandoffSpec": {
      "type": "object",
      "required": ["bindings"],
      "properties": {
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/requestSequenceHandoffBindingSpec"
          }
        }
      },
      "additionalProperties": false
    },
    "requestSequenceHandoffBindingSpec": {
      "type": "object",
      "required": ["kind", "target"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["value", "file"]
        },
        "target": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "step": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "required": {
          "type": "boolean"
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "requestPollSpec": {
      "type": "object",
      "properties": {
        "interval_ms": {
          "type": "number"
        },
        "timeout_ms": {
          "type": "number"
        }
      },
      "additionalProperties": true
    }
  }
}
