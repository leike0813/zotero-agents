{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow.schema.json",
  "title": "WorkflowManifest",
  "type": "object",
  "required": ["id", "label", "provider", "hooks"],
  "properties": {
    "id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "label": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "provider": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "version": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "display": {
      "$ref": "#/$defs/workflowDisplaySpec"
    },
    "taskNameTemplate": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "i18n": {
      "$ref": "#/$defs/workflowI18nSpec"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/parameterSchema"
      }
    },
    "inputs": {
      "$ref": "#/$defs/inputsSpec"
    },
    "trigger": {
      "$ref": "#/$defs/triggerSpec"
    },
    "execution": {
      "$ref": "#/$defs/executionSpec"
    },
    "result": {
      "$ref": "#/$defs/resultSpec"
    },
    "request": {
      "$ref": "#/$defs/requestSpec"
    },
    "hooks": {
      "$ref": "#/$defs/hooksSpec"
    },
    "backend": false,
    "defaults": false
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          {
            "properties": {
              "provider": {
                "const": "skillrunner"
              }
            },
            "required": ["provider"]
          },
          {
            "properties": {
              "request": {
                "type": "object",
                "properties": {
                  "kind": {
                    "enum": ["skillrunner.job.v1", "skillrunner.sequence.v1"]
                  }
                },
                "required": ["kind"]
              }
            },
            "required": ["request"]
          }
        ]
      },
      "then": {
        "required": ["execution"],
        "properties": {
          "execution": {
            "type": "object",
            "properties": {
              "skillrunner_mode": {
                "type": "string",
                "enum": ["auto", "interactive"]
              }
            },
            "required": ["skillrunner_mode"]
          }
        }
      }
    },
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "request": {
                "type": "object",
                "properties": {
                  "kind": {
                    "const": "skillrunner.sequence.v1"
                  }
                },
                "required": ["kind"]
              }
            },
            "required": ["request"]
          },
          {
            "not": {
              "properties": {
                "hooks": {
                  "type": "object",
                  "properties": {
                    "buildRequest": {}
                  },
                  "required": ["buildRequest"]
                }
              },
              "required": ["hooks"]
            }
          }
        ]
      },
      "then": {
        "properties": {
          "provider": {
            "const": "acp"
          },
          "result": {
            "type": "object",
            "properties": {
              "final_step_id": {
                "$ref": "#/$defs/nonEmptyString"
              }
            },
            "required": ["final_step_id"]
          },
          "request": {
            "type": "object",
            "properties": {
              "sequence": {
                "$ref": "#/$defs/requestSequenceSpec"
              }
            },
            "required": ["sequence"]
          }
        },
        "required": ["provider", "result"]
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "workflowI18nSpec": {
      "type": "object",
      "properties": {
        "defaultLocale": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "messages": {
          "$ref": "#/$defs/workflowI18nMessages"
        }
      },
      "additionalProperties": false
    },
    "workflowI18nMessages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "workflowDisplaySpec": {
      "type": "object",
      "properties": {
        "core": {
          "type": "boolean"
        },
        "emoji": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16
        }
      },
      "additionalProperties": false
    },
    "parameterSchema": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean"]
        },
        "visible_if": {
          "$ref": "#/$defs/parameterVisibleIf"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "default": {},
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": {}
        },
        "allowCustom": {
          "type": "boolean"
        },
        "optionsSource": {
          "$ref": "#/$defs/parameterOptionsSource"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "required": ["min", "max"],
            "properties": {
              "min": {
                "type": "number"
              },
              "max": {
                "type": "number"
              }
            }
          },
          "then": {
            "properties": {
              "min": {
                "type": "number",
                "maximum": {
                  "$data": "1/max"
                }
              }
            }
          }
        }
      ],
      "additionalProperties": true
    },
    "parameterVisibleIf": {
      "type": "object",
      "required": ["parameter", "equals"],
      "properties": {
        "parameter": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "equals": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "parameterOptionsSource": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "library": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["current", "user"]
            },
            {
              "type": "number"
            }
          ]
        },
        "includeEmpty": {
          "type": "boolean"
        },
        "valueFormat": {
          "type": "string"
        },
        "labelFormat": {
          "type": "string"
        },
        "allowStale": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "hooksSpec": {
      "type": "object",
      "required": ["applyResult"],
      "properties": {
        "filterInputs": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "buildRequest": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "normalizeSettings": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "applyResult": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "inputsSpec": {
      "type": "object",
      "required": ["unit"],
      "properties": {
        "unit": {
          "type": "string",
          "enum": ["attachment", "parent", "note", "workflow"]
        },
        "accepts": {
          "type": "object",
          "properties": {
            "mime": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "per_parent": {
          "type": "object",
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "triggerSpec": {
      "type": "object",
      "properties": {
        "requiresSelection": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "executionSpec": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["auto", "sync", "async"]
        },
        "mcp": {
          "type": "object",
          "properties": {
            "requiredTools": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        },
        "zoteroHostAccess": {
          "type": "object",
          "properties": {
            "required": {
              "type": "boolean"
            },
            "allowWriteApprovalBypass": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "skillrunner_mode": {
          "type": "string",
          "enum": ["auto", "interactive"]
        },
        "poll_interval_ms": {
          "type": "number"
        },
        "timeout_ms": {
          "type": "number"
        },
        "feedback": {
          "$ref": "#/$defs/executionFeedbackSpec"
        }
      },
      "additionalProperties": false
    },
    "executionFeedbackSpec": {
      "type": "object",
      "properties": {
        "showNotifications": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "resultSpec": {
      "type": "object",
      "properties": {
        "fetch": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["bundle", "result"]
            }
          },
          "additionalProperties": false
        },
        "expects": {
          "type": "object",
          "properties": {
            "result_json": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "artifacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "final_step_id": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "requestSpec": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "create": {
          "$ref": "#/$defs/requestCreateSpec"
        },
        "input": {
          "$ref": "#/$defs/requestInputSpec"
        },
        "poll": {
          "$ref": "#/$defs/requestPollSpec"
        },
        "sequence": {
          "$ref": "#/$defs/requestSequenceSpec"
        },
        "result": false
      },
      "additionalProperties": true
    },
    "requestCreateSpec": {
      "type": "object",
      "properties": {
        "skill_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "skill_source": {
          "type": "string",
          "enum": ["local-package", "installed"]
        },
        "engine": false,
        "parameter": false,
        "model": false,
        "runtime_options": false
      },
      "additionalProperties": true
    },
    "requestInputSpec": {
      "type": "object",
      "properties": {
        "upload": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/requestUploadFileSpec"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "requestUploadFileSpec": {
      "type": "object",
      "required": ["key", "from"],
      "properties": {
        "key": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "Field name written to request.input.<key> for uploaded file relative path."
        },
        "from": {
          "type": "string",
          "enum": ["selected.markdown", "selected.pdf", "selected.source"]
        }
      },
      "additionalProperties": false
    },
    "requestSequenceSpec": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/requestSequenceStepSpec"
          }
        }
      },
      "additionalProperties": false
    },
    "requestSequenceStepSpec": {
      "type": "object",
      "required": ["id", "skill_id"],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "skill_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "input": {
          "type": "object",
          "additionalProperties": true
        },
        "parameter": {
          "type": "object",
          "additionalProperties": true
        },
        "fetch_type": {
          "type": "string",
          "enum": ["bundle", "result"]
        },
        "workspace": {
          "type": "string",
          "enum": ["new", "reuse-workflow"]
        },
        "handoff": {
          "$ref": "#/$defs/requestSequenceHandoffSpec"
        }
      },
      "additionalProperties": false
    },
    "requestSequenceHandoffSpec": {
      "type": "object",
      "properties": {
        "from_step": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "required": {
          "type": "boolean"
        },
        "pass_through": {
          "type": "boolean"
        },
        "input": {
          "$ref": "#/$defs/stringMap"
        },
        "parameter": {
          "$ref": "#/$defs/stringMap"
        },
        "defaults": {
          "type": "object",
          "properties": {
            "input": {
              "type": "object",
              "additionalProperties": true
            },
            "parameter": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "requestPollSpec": {
      "type": "object",
      "properties": {
        "interval_ms": {
          "type": "number"
        },
        "timeout_ms": {
          "type": "number"
        }
      },
      "additionalProperties": true
    }
  }
}
