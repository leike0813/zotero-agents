{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topic Synthesis Structured Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "schema_version",
    "language",
    "topic",
    "summary",
    "positioning",
    "taxonomy",
    "comparison_matrix",
    "claims",
    "timeline_events",
    "paper_evidence",
    "external_literature_analysis",
    "debates",
    "coverage",
    "gaps",
    "review_outline",
    "evidence_map",
    "source_artifacts",
    "diagnostics"
  ],
  "properties": {
    "schema_id": { "const": "synthesis.topic_synthesis_artifact" },
    "schema_version": { "type": "string" },
    "language": { "type": "string" },
    "topic": { "type": "object" },
    "summary": { "type": "object" },
    "positioning": { "type": "object" },
    "taxonomy": { "type": "object" },
    "comparison_matrix": { "type": "object" },
    "claims": { "type": "array" },
    "timeline_events": { "type": "array" },
    "paper_evidence": { "type": "array" },
    "external_literature_analysis": { "type": "object" },
    "debates": { "type": "array" },
    "coverage": { "type": "object" },
    "gaps": { "type": "array" },
    "review_outline": { "type": "object" },
    "evidence_map": { "type": "object" },
    "source_artifacts": { "type": "array" },
    "diagnostics": { "type": "object" }
  },
  "not": { "required": ["markdown"] }
}
