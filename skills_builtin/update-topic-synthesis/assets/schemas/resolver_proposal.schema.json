{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.resolver_proposal_payload",
  "type": "object",
  "required": ["resolver"],
  "properties": {
    "resolver": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["tag_query", "collection", "explicit", "mixed"]
        }
      },
      "additionalProperties": true
    },
    "resolver_reasoning": { "type": "string" },
    "operation_intent": {
      "type": "string",
      "enum": ["create", "update_full", "update_patch"]
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "diagnostics": {
      "type": "array",
      "items": {}
    }
  },
  "additionalProperties": false
}
