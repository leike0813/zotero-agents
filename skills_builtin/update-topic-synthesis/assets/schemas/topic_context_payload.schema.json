{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.update_topic_context_payload",
  "type": "object",
  "required": ["topic_context"],
  "properties": {
    "topic_context": {
      "type": "object",
      "required": ["topic_id"],
      "properties": {
        "topic_id": { "type": "string", "minLength": 1 },
        "topic_definition": { "type": "object" },
        "current_hashes": { "type": "object" },
        "section_hashes": { "type": "object" },
        "recommended_update": { "type": "object" }
      },
      "additionalProperties": true
    },
    "update_assessment": {
      "type": "object",
      "properties": {
        "operation": { "enum": ["update_full", "update_patch"] },
        "changed_sections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reason": { "type": "string" },
        "diagnostics": { "type": "array" }
      },
      "additionalProperties": true
    },
    "diagnostics": { "type": "array", "default": [] }
  },
  "additionalProperties": false
}
