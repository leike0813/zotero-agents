{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "query": { "type": "string", "minLength": 1 },
    "searchMode": {
      "type": "string",
      "enum": [
        "auto",
        "topic_expansion",
        "paper_seed_expansion",
        "targeted_ingest"
      ]
    },
    "targetCollection": { "type": "string" }
  },
  "required": ["query"],
  "additionalProperties": true
}
