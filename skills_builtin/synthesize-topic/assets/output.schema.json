{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Synthesis Topic Result Bundle",
  "type": "object",
  "additionalProperties": true,
  "not": { "required": ["markdown"] },
  "required": [
    "kind",
    "mode",
    "base_hashes",
    "topic_definition",
    "topic_resolver",
    "resolved_paper_set",
    "resolver_diagnostics",
    "artifact_metadata",
    "markdown_path",
    "timeline"
  ],
  "properties": {
    "__SKILL_DONE__": { "type": "boolean" },
    "kind": { "const": "topic_synthesis" },
    "mode": { "enum": ["create", "update"] },
    "base_hashes": {
      "type": "object",
      "required": ["artifact", "metadata", "index"],
      "properties": {
        "artifact": { "type": "string" },
        "metadata": { "type": "string" },
        "index": { "type": "string" }
      }
    },
    "topic_definition": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "topic_resolver": { "type": "object" },
    "resolved_paper_set": {
      "type": "object",
      "required": ["papers"],
      "properties": {
        "papers": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["paper_ref"],
                "properties": {
                  "paper_ref": { "type": "string", "minLength": 1 },
                  "match_reasons": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            ]
          }
        }
      }
    },
    "resolver_diagnostics": { "type": "object" },
    "artifact_metadata": { "type": "object" },
    "markdown_path": { "type": "string", "minLength": 1 },
    "timeline": {}
  }
}
