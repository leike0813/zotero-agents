{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Synthesis Topic Resolver",
  "type": "object",
  "required": ["mode"],
  "oneOf": [
    { "$ref": "#/definitions/tagQueryResolver" },
    { "$ref": "#/definitions/collectionResolver" },
    { "$ref": "#/definitions/explicitResolver" },
    { "$ref": "#/definitions/mixedResolver" }
  ],
  "definitions": {
    "tagValue": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "and": { "$ref": "#/definitions/tagValueList" },
            "or": { "$ref": "#/definitions/tagValueList" },
            "not": { "$ref": "#/definitions/tagValueList" }
          }
        }
      ]
    },
    "tagValueList": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "tagQueryResolver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "query"],
      "properties": {
        "mode": { "const": "tag_query" },
        "query": { "$ref": "#/definitions/tagValue" }
      }
    },
    "collectionRef": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "collectionResolver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "const": "collection" },
        "collection": { "$ref": "#/definitions/collectionRef" },
        "collections": { "$ref": "#/definitions/collectionRef" },
        "collection_key": { "$ref": "#/definitions/collectionRef" },
        "collection_keys": { "$ref": "#/definitions/collectionRef" },
        "collection_id": { "$ref": "#/definitions/collectionRef" },
        "collection_ids": { "$ref": "#/definitions/collectionRef" },
        "key": { "$ref": "#/definitions/collectionRef" },
        "id": { "$ref": "#/definitions/collectionRef" }
      }
    },
    "explicitResolver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "paper_refs"],
      "properties": {
        "mode": { "const": "explicit" },
        "paper_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "mixedResolver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "include"],
      "properties": {
        "mode": { "const": "mixed" },
        "include": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#" }
        },
        "exclude": {
          "type": "array",
          "items": { "$ref": "#" }
        }
      }
    }
  }
}
