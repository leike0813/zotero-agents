{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Manuscript Literature Framing Result",
  "type": "object",
  "additionalProperties": true,
  "oneOf": [
    {
      "title": "Completed manuscript literature framing",
      "type": "object",
      "required": [
        "kind",
        "title",
        "language",
        "artifact_manifest_path"
      ],
      "properties": {
        "kind": { "const": "writing.manuscript_literature_framing" },
        "title": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "topic_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifact_manifest_path": {
          "type": "string",
          "minLength": 1,
          "x-type": "artifact-manifest",
          "x-role": "artifact-manifest"
        }
      }
    },
    {
      "title": "Canceled manuscript literature framing",
      "type": "object",
      "required": ["kind", "status", "reason", "message"],
      "properties": {
        "kind": { "const": "manuscript_literature_framing_canceled" },
        "status": { "const": "canceled" },
        "reason": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "paperTitle": { "type": "string" }
      }
    }
  ]
}
