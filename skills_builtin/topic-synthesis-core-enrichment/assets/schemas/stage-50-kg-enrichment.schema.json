{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.stage_50_kg_enrichment.schema.json",
  "title": "Stage 50 KG enrichment payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "concept_details",
    "topic_relation_candidates",
    "topic_matching_terms",
    "diagnostics"
  ],
  "properties": {
    "concept_details": {
      "type": "array",
      "items": { "type": "object" }
    },
    "topic_relation_candidates": {
      "type": "array",
      "items": { "type": "object" }
    },
    "topic_matching_terms": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include_terms",
        "must_have_terms",
        "methods",
        "exclude_terms",
        "diagnostics"
      ],
      "properties": {
        "include_terms": { "type": "array", "items": { "type": "string" } },
        "must_have_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "methods": { "type": "array", "items": { "type": "string" } },
        "exclude_terms": { "type": "array", "items": { "type": "string" } },
        "diagnostics": { "type": "array", "items": { "type": "object" } }
      }
    },
    "diagnostics": { "type": "array", "items": { "type": "object" } }
  },
  "examples": [
    {
      "concept_details": [],
      "topic_relation_candidates": [],
      "topic_matching_terms": {
        "include_terms": [],
        "must_have_terms": [],
        "methods": [],
        "exclude_terms": [],
        "diagnostics": []
      },
      "diagnostics": []
    }
  ]
}
