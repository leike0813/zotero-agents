{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Debug Sequence Probe Result",
  "type": "object",
  "required": [
    "kind",
    "probe_id",
    "status",
    "checks",
    "diagnostics"
  ],
  "properties": {
    "kind": { "const": "debug_sequence_probe_result" },
    "probe_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ok", "failed"] },
    "public_marker": { "type": "string" },
    "secret_marker": { "type": "string" },
    "sentinel_path": { "type": "string" },
    "artifact_path": {
      "type": "string",
      "x-type": "artifact",
      "x-role": "sequence-file-handoff-artifact"
    },
    "workspace_cwd": { "type": "string" },
    "checks": { "type": "array", "items": { "type": "object" } },
    "diagnostics": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
