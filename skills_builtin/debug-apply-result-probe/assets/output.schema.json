{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Debug Apply Result Probe Result",
  "type": "object",
  "required": [
    "kind",
    "workflow_id",
    "step_id",
    "run_key",
    "apply_mode",
    "tag",
    "message"
  ],
  "properties": {
    "kind": { "const": "debug_apply_contract_result" },
    "workflow_id": { "type": "string", "minLength": 1 },
    "step_id": { "type": "string", "minLength": 1 },
    "run_key": { "type": "string", "minLength": 1 },
    "apply_mode": { "const": "result" },
    "tag": { "type": "string", "minLength": 1 },
    "message": { "type": "string" }
  },
  "additionalProperties": true
}

