{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zotero-skills.local/schemas/synthesis/taxonomy_section.schema.json",
  "title": "Topic Synthesis Taxonomy Section",
  "description": "Section-level schema for research-route analysis. The section summary is the report-ready integrated route analysis, not a list of route card abstracts.",
  "type": "object",
  "additionalProperties": true,
  "required": ["primary_axis", "axis_rationale", "summary", "nodes"],
  "properties": {
    "primary_axis": { "type": "string", "minLength": 1 },
    "axis_rationale": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "dominant_routes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "emerging_routes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "route_relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["from", "to", "relation", "explanation"],
            "properties": {
              "from": { "type": "string", "minLength": 1 },
              "to": { "type": "string", "minLength": 1 },
              "relation": { "type": "string", "minLength": 1 },
              "explanation": { "type": "string", "minLength": 1 }
            }
          }
        },
        "main_tradeoffs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "report_chapter_hint": { "type": "string", "minLength": 1 }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "label",
          "definition",
          "core_problem",
          "mechanism",
          "representative_papers",
          "main_contributions",
          "strengths",
          "limitations",
          "maturity",
          "relation_to_other_routes",
          "review_angle",
          "evidence_map_refs"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "definition": { "type": "string", "minLength": 1 },
          "core_problem": { "type": "string", "minLength": 1 },
          "mechanism": { "type": "string", "minLength": 1 },
          "representative_papers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "main_contributions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "strengths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "limitations": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "maturity": { "type": "string", "minLength": 1 },
          "relation_to_other_routes": { "type": "string", "minLength": 1 },
          "review_angle": { "type": "string", "minLength": 1 },
          "paper_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "evidence_map_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
