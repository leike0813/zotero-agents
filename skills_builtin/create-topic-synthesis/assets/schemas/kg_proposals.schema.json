{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topic Synthesis KG Proposals",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "schema_version",
    "concept_cards_proposal",
    "topic_graph_relation_proposals",
    "topic_interest_metadata"
  ],
  "properties": {
    "schema_id": { "const": "synthesis.topic_synthesis_kg_proposals" },
    "schema_version": { "type": "string", "minLength": 1 },
    "concept_cards_proposal": {
      "type": "object",
      "additionalProperties": true,
      "required": ["cards", "diagnostics"],
      "properties": {
        "schema_id": { "const": "synthesis.concept_cards_proposal" },
        "schema_version": { "type": "string" },
        "topic_id": { "type": "string" },
        "cards": { "type": "array" },
        "diagnostics": { "type": "array" }
      }
    },
    "topic_graph_relation_proposals": {
      "type": "object",
      "additionalProperties": true,
      "required": ["proposals", "diagnostics"],
      "properties": {
        "schema_id": { "const": "synthesis.topic_graph_relation_proposals" },
        "schema_version": { "type": "string" },
        "source_topic_id": { "type": "string" },
        "proposals": { "type": "array" },
        "diagnostics": { "type": "array" }
      }
    },
    "topic_interest_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "topic_id",
        "include_terms",
        "must_have_terms",
        "methods",
        "exclude_terms",
        "seed_literature_item_ids"
      ],
      "properties": {
        "schema": { "const": "topic_interest_metadata.v1" },
        "topic_id": { "type": "string", "minLength": 1 },
        "include_terms": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1 }
        },
        "must_have_terms": {
          "type": "array",
          "maxItems": 6,
          "items": { "type": "string", "minLength": 1 }
        },
        "methods": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1 }
        },
        "exclude_terms": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1 }
        },
        "seed_literature_item_ids": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "minLength": 1 }
        },
        "diagnostics": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
