{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.route_timeline_synthesis",
  "type": "object",
  "required": ["taxonomy", "timeline_events"],
  "properties": {
    "taxonomy": {
      "type": "object",
      "required": ["summary", "nodes"],
      "properties": {
        "summary": { "type": "object" },
        "nodes": { "type": "array", "items": { "type": "object" }, "minItems": 1 }
      },
      "additionalProperties": true
    },
    "timeline_events": {
      "type": "object",
      "required": ["summary", "events"],
      "properties": {
        "summary": { "type": "object" },
        "events": { "type": "array", "items": { "type": "object" }, "minItems": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
