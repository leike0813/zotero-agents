{
  "name": "zotero-skills",
  "type": "module",
  "version": "0.4.0",
  "description": "A Zotero plugin for execute agent skills using Skill-Runner backend",
  "config": {
    "addonName": "Zotero Skills",
    "addonID": "zotero-skills@leike0813@gmail.com",
    "addonRef": "zotero-skills",
    "addonInstance": "ZoteroSkills",
    "prefsPrefix": "extensions.zotero.zotero-skills"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leike0813/Zotero-Skills.git"
  },
  "author": "Joshua Reed",
  "bugs": {
    "url": "https://github.com/leike0813/Zotero-Skills/issues"
  },
  "homepage": "https://github.com/leike0813/Zotero-Skills#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "tsx scripts/run-zotero-start-with-mock.ts start:raw",
    "start:raw": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "check:builtin-workflow-manifest": "tsx scripts/check-builtin-workflow-manifest.ts",
    "check:localization-governance": "tsx scripts/check-localization-governance.ts",
    "check:ssot-invariants": "tsx scripts/check-skillrunner-ssot-invariants.ts",
    "package:zotero-bridge-cli": "node scripts/package-zotero-bridge-cli.mjs",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "npm run test:lite",
    "test:lite": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli lite",
    "test:full": "npm run test:zotero:full",
    "test:gate:pr": "tsx scripts/run-ci-gate.ts pr",
    "test:gate:release": "tsx scripts/run-ci-gate.ts release",
    "test:zotero": "npm run test:zotero:lite",
    "test:zotero:lite": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli lite",
    "test:zotero:case": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli",
    "test:zotero:full": "tsx scripts/run-zotero-full-suite.ts",
    "test:zotero:core": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli lite core",
    "test:zotero:core:full": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli full core",
    "test:zotero:ui": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli lite ui",
    "test:zotero:ui:full": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli full ui",
    "test:zotero:workflow": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli lite workflow",
    "test:zotero:workflow:full": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli full workflow",
    "test:zotero:raw": "tsx scripts/run-zotero-test-with-mock.ts test:zotero:cli",
    "test:zotero:cli": "zotero-plugin test",
    "test:node": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw lite",
    "test:node:lite": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw lite",
    "test:node:full": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw full",
    "test:node:core": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw:core lite core",
    "test:node:core:full": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw:core full core",
    "test:node:ui": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw:ui lite ui",
    "test:node:ui:full": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw:ui full ui",
    "test:node:workflow": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw:workflow lite workflow",
    "test:node:workflow:full": "tsx scripts/run-zotero-test-with-mock.ts test:node:raw:workflow full workflow",
    "test:node:raw:core": "tsx node_modules/mocha/bin/mocha \"test/core/**/*.test.ts\" \"test/node/core/**/*.test.ts\" --require test/setup/zotero-mock.ts",
    "test:node:raw:ui": "tsx node_modules/mocha/bin/mocha \"test/ui/**/*.test.ts\" --require test/setup/zotero-mock.ts",
    "test:node:raw:workflow": "tsx node_modules/mocha/bin/mocha \"test/workflow-*/**/*.test.ts\" --require test/setup/zotero-mock.ts",
    "test:node:raw": "tsx node_modules/mocha/bin/mocha \"test/**/*.test.ts\" --require test/setup/zotero-mock.ts",
    "test:synthesis:invariants": "tsx node_modules/mocha/bin/mocha \"test/core/121-synthesis-paper-registry.test.ts\" \"test/core/125-synthesis-tab-ui.test.ts\" \"test/core/129-synthesis-layer-integration.test.ts\" \"test/core/132-topic-synthesis-structured-artifact-contract.test.ts\" \"test/core/143-synthesis-literature-registry-citation-graph.test.ts\" \"test/core/146-synthesis-repository-foundation.test.ts\" \"test/core/151-synthesis-reference-resolution-matcher.test.ts\" \"test/core/152-synthesis-invariant-guards.test.ts\" --require test/setup/zotero-mock.ts --grep \"Synthesis invariant guards|\\[inv\\.\" --exit",
    "mock:skillrunner": "tsx scripts/mock-skillrunner-serve.ts",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "d3-force": "^3.0.0",
    "graphology": "^0.26.0",
    "marked": "^16.4.2",
    "pako": "^2.1.0",
    "sigma": "^3.0.3",
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/chai": "^5.2.3",
    "@types/d3-force": "^3.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@types/pako": "^2.0.4",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
