{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.topic_synthesis_stdout_envelope.schema.json",
  "title": "Topic synthesis skill business output envelope",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "handoff",
        "operation",
        "db_path",
        "handoff_manifest_path",
        "next_skill_id"
      ],
      "properties": {
        "kind": { "const": "topic_synthesis_handoff" },
        "handoff": {
          "enum": ["prepare_analysis_context", "core_enrichment"]
        },
        "operation": {
          "enum": ["create", "update_full"]
        },
        "db_path": { "const": "runtime/topic-synthesis.sqlite" },
        "handoff_manifest_path": { "type": "string", "minLength": 1 },
        "next_skill_id": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "operation",
        "analysis_manifest_path",
        "candidate_output_path"
      ],
      "properties": {
        "kind": { "const": "topic_synthesis" },
        "operation": {
          "enum": ["create", "update_full"]
        },
        "analysis_manifest_path": { "type": "string", "minLength": 1 },
        "candidate_output_path": {
          "const": "result/final-output.candidate.json"
        }
      }
    }
  ]
}
