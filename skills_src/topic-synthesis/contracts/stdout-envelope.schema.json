{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.topic_synthesis_stdout_envelope.schema.json",
  "title": "Topic synthesis skill business output envelope",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "handoff",
        "operation",
        "db_path",
        "handoff_manifest_path",
        "next_skill_id"
      ],
      "properties": {
        "kind": { "const": "topic_synthesis_handoff" },
        "handoff": {
          "enum": ["prepare_analysis_context", "core_enrichment"]
        },
        "operation": {
          "enum": ["create", "update_full"]
        },
        "db_path": {
          "type": "string",
          "minLength": 1,
          "x-type": "artifact",
          "x-role": "runtime-state-db"
        },
        "handoff_manifest_path": {
          "type": "string",
          "minLength": 1,
          "x-type": "artifact-manifest",
          "x-role": "artifact-manifest"
        },
        "next_skill_id": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "operation",
        "artifact_manifest_path"
      ],
      "properties": {
        "kind": { "const": "topic_synthesis" },
        "operation": {
          "enum": ["create", "update_full"]
        },
        "artifact_manifest_path": {
          "type": "string",
          "minLength": 1,
          "x-type": "artifact-manifest",
          "x-role": "artifact-manifest"
        }
      }
    }
  ]
}
