{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.stage_10_update_topic_context.schema.json",
  "title": "Stage 10 update decision and resolver payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["update_decision"],
  "properties": {
    "update_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "reason", "message"],
      "properties": {
        "action": {
          "enum": ["cancel", "continue"]
        },
        "reason": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "resolver": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": ["tag"]
        },
        {
          "required": ["collection_key"]
        },
        {
          "required": ["paper_refs"]
        }
      ],
      "properties": {
        "tag": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "minProperties": 1,
              "properties": {
                "and": {
                  "$ref": "#/$defs/string_or_string_array"
                },
                "or": {
                  "$ref": "#/$defs/string_or_string_array"
                },
                "not": {
                  "$ref": "#/$defs/string_or_string_array"
                }
              }
            }
          ]
        },
        "collection_key": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "paper_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "combine": {
          "enum": ["union", "intersection"]
        }
      }
    },
    "resolver_reasoning": {
      "type": "string"
    }
  },
  "examples": [
    {
      "update_decision": {
        "action": "continue",
        "reason": "The preflight audit shows new source material candidates.",
        "message": "Proceeding with a current-state update."
      },
      "resolver": {
        "paper_refs": ["1:DETR", "1:DINO"],
        "combine": "union"
      },
      "resolver_reasoning": "The proposal keeps the current resolver refs and adds newly relevant resolved papers."
    }
  ],
  "$defs": {
    "string_or_string_array": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    }
  }
}
