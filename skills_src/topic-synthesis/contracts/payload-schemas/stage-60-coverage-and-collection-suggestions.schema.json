{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.stage_60_coverage_and_collection_suggestions.schema.json",
  "title": "Stage 60 coverage and collection suggestions payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "coverage_verdict",
    "coverage_reason",
    "coverage_caveats",
    "external_context_summary",
    "suggested_collection_directions"
  ],
  "properties": {
    "coverage_verdict": {
      "enum": [
        "sufficient",
        "partial",
        "insufficient",
        "severely_missing",
        "unknown"
      ]
    },
    "coverage_reason": {
      "type": "string",
      "minLength": 1
    },
    "coverage_caveats": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "external_context_summary": {
      "type": "string",
      "minLength": 1
    },
    "suggested_collection_directions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "direction",
          "reason",
          "example_titles_or_terms",
          "priority"
        ],
        "properties": {
          "direction": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "example_titles_or_terms": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority": {
            "enum": ["high", "medium", "low", "unknown"]
          }
        }
      }
    }
  },
  "examples": [
    {
      "coverage_verdict": "partial",
      "coverage_reason": "当前库内材料覆盖核心路线，但仍缺少效率和部署方向的代表文献。",
      "coverage_caveats": [
        {
          "type": "library_coverage_gap",
          "note": "效率导向和部署导向的变体覆盖不足。"
        }
      ],
      "external_context_summary": "外部 context 指向若干邻近变体，可作为后续补充方向。",
      "suggested_collection_directions": [
        {
          "direction": "补充效率导向的 DETR 变体。",
          "reason": "这些文献有助于解释部署和 latency tradeoff。",
          "example_titles_or_terms": ["Deformable DETR"],
          "priority": "medium"
        }
      ]
    }
  ]
}
