{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.stage_30_prepare_analysis_context.schema.json",
  "title": "Stage 30 prepare analysis context payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["assessments"],
  "properties": {
    "assessments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "paper_ref",
          "relevance_level",
          "relevance_reason",
          "paper_quality_level",
          "paper_quality_reason",
          "core_digest",
          "caveats",
          "diagnostics"
        ],
        "properties": {
          "paper_ref": { "type": "string", "minLength": 1 },
          "relevance_level": {
            "enum": ["core", "related", "external", "irrelevant", "unknown"]
          },
          "relevance_reason": { "type": "string" },
          "paper_quality_level": {
            "enum": ["high", "medium", "low", "unknown"]
          },
          "paper_quality_reason": { "type": "string" },
          "core_digest": { "type": "string" },
          "caveats": { "type": "array", "items": { "type": "string" } },
          "diagnostics": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    }
  },
  "examples": [
    {
      "assessments": [
        {
          "paper_ref": "1:ABC",
          "relevance_level": "core",
          "relevance_reason": "",
          "paper_quality_level": "high",
          "paper_quality_reason": "",
          "core_digest": "",
          "caveats": [],
          "diagnostics": []
        }
      ]
    }
  ]
}
