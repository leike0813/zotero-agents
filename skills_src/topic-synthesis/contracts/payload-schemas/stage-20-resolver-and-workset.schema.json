{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.stage_20_resolver_and_workset.schema.json",
  "title": "Stage 20 resolver and workset payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["resolver", "resolver_reasoning", "operation_intent"],
  "properties": {
    "resolver": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": ["tag"]
        },
        {
          "required": ["collection_key"]
        },
        {
          "required": ["paper_refs"]
        }
      ],
      "properties": {
        "tag": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "minProperties": 1,
              "properties": {
                "and": {
                  "$ref": "#/$defs/string_or_string_array"
                },
                "or": {
                  "$ref": "#/$defs/string_or_string_array"
                },
                "not": {
                  "$ref": "#/$defs/string_or_string_array"
                }
              }
            }
          ]
        },
        "collection_key": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "paper_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "combine": {
          "enum": ["union", "intersection"]
        }
      }
    },
    "resolver_reasoning": {
      "type": "string"
    },
    "operation_intent": {
      "enum": ["create", "unknown"]
    }
  },
  "examples": [
    {
      "resolver": {
        "tag": {
          "and": ["object-detection", "detr"]
        },
        "combine": "union"
      },
      "resolver_reasoning": "",
      "operation_intent": "create"
    }
  ],
  "$defs": {
    "string_or_string_array": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    }
  }
}
