{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthesis.stage_20_resolver_and_workset.schema.json",
  "title": "Stage 20 resolver and workset payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resolver",
    "resolver_reasoning",
    "operation_intent",
    "diagnostics"
  ],
  "properties": {
    "resolver": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode"],
      "anyOf": [{ "required": ["query"] }, { "required": ["paper_refs"] }],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "query": { "type": "object" },
        "paper_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "resolver_reasoning": { "type": "string" },
    "operation_intent": {
      "enum": ["create", "update_full", "update_patch", "unknown"]
    },
    "diagnostics": { "type": "array", "items": { "type": "object" } }
  },
  "examples": [
    {
      "resolver": {
        "mode": "tag_query",
        "query": {
          "and": ["object-detection", "detr"]
        }
      },
      "resolver_reasoning": "",
      "operation_intent": "create",
      "diagnostics": []
    }
  ]
}
