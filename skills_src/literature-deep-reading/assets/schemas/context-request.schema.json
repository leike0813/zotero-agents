    },
    "request_concept_context": {
      "type": "boolean",
      "default": false
    },
    "concept_labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "request_citation_graph": {
      "type": "boolean",
      "default": false
    },
    "citation_graph_depth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "default": 2
