{
  "$id": "literature-deep-reading.reading-enrichment.v0",
  "type": "object",
  "properties": {
    "preface_title": {
      "type": "string",
      "minLength": 1
    },
    "preface_cards": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/titledText"
      }
    },
    "preface_reading_path": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preface_goal": {
      "type": "string",
      "minLength": 1
    },
    "preface_concepts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preface_warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "preface_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/questionAnswer"
      }
    },
    "section_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "section_anchor": {
            "type": "string",
            "minLength": 1
          },
          "reading_goal": {
            "type": "string",
            "minLength": 1
          },
          "concepts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "misread_warnings": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/questionAnswer"
            }
          },
          "citation_note_body": {
            "type": "string",
            "minLength": 1
          },
          "citation_reference_roles": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reference_id": {
                  "type": "string",
                  "minLength": 1
                },
                "role": {
                  "type": "string",
                  "minLength": 1
                },
                "note": {
                  "type": "string"
                }
              },
              "required": ["reference_id", "role"],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "section_anchor",
          "reading_goal",
          "misread_warnings",
          "questions",
          "citation_note_body",
          "citation_reference_roles"
        ],
        "additionalProperties": false
      }
    },
    "section_roles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "section_anchor": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": ["main", "bibliography", "appendix"]
          },
          "reason": {
            "type": "string"
          }
        },
        "required": ["section_anchor", "role"],
        "additionalProperties": false
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "kind": {
            "type": "string"
          },
          "definition": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["label", "definition"],
        "additionalProperties": false
      }
    },
    "reference_digest_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "reference_id": {
            "type": "string",
            "minLength": 1
          },
          "role_in_current_paper": {
            "type": "string",
            "minLength": 1
          },
          "why_open": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        },
        "required": ["reference_id", "role_in_current_paper", "why_open"],
        "additionalProperties": false
      }
    },
    "summary_fallback_enabled": {
      "type": "boolean"
    },
    "summary_fallback_sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/titledText"
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "anchor": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "target": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["label", "target"],
              "additionalProperties": false
            }
          }
        },
        "required": ["title", "body"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "preface_title",
    "preface_cards",
    "preface_reading_path",
    "preface_goal",
    "preface_questions",
    "section_notes",
    "summary_fallback_enabled",
    "extensions"
  ],
  "additionalProperties": false,
  "$defs": {
    "titledText": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["title", "body"],
      "additionalProperties": false
    },
    "questionAnswer": {
      "type": "object",
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "answer": {
          "type": "string",
          "minLength": 1
        },
        "evidence_kind": {
          "type": "string"
        },
        "evidence_ref": {
          "type": "string"
        }
      },
      "required": ["question", "answer"],
      "additionalProperties": false
    }
  }
}
