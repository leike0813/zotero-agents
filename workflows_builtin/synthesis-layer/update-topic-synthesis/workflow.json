{
  "id": "update-topic-synthesis",
  "label": "Update Topic Synthesis",
  "provider": "acp",
  "version": "0.2.0",
  "taskNameTemplate": "Update synthesis: {topicId}",
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "parameters": {
    "topicId": {
      "type": "string",
      "title": "Topic ID",
      "description": "Existing synthesis topic id. The host derives update scope, mode, reason, and language from the selected topic.",
      "allowCustom": false,
      "optionsSource": {
        "kind": "synthesis.topics",
        "valueFormat": "topicId",
        "labelFormat": "title",
        "filter": "updatable"
      }
    }
  },
  "request": {
    "kind": "skillrunner.job.v1",
    "create": {
      "skill_id": "update-topic-synthesis"
    }
  },
  "execution": {
    "mode": "auto",
    "zoteroHostAccess": {
      "required": true
    },
    "skillrunner_mode": "interactive",
    "timeout_ms": 1200000
  },
  "result": {
    "fetch": { "type": "result" },
    "expects": {
      "result_json": "result/final-output.candidate.json"
    }
  },
  "hooks": {
    "buildRequest": "hooks/buildRequest.mjs",
    "applyResult": "../hooks/applyTopicSynthesisResult.mjs"
  }
}
