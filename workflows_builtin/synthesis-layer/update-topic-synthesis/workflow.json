{
  "id": "update-topic-synthesis",
  "label": "Update Topic Synthesis",
  "provider": "acp",
  "version": "0.2.0",
  "display": {
    "core": true,
    "emoji": "🔄"
  },
  "taskNameTemplate": "Update synthesis: {topicId}",
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "parameters": {
    "topicId": {
      "type": "string",
      "title": "Topic ID",
      "description": "Existing synthesis topic id. The host derives update scope, mode, reason, and language from the selected topic.",
      "allowCustom": false,
      "optionsSource": {
        "kind": "synthesis.topics",
        "valueFormat": "topicId",
        "labelFormat": "title",
        "filter": "updatable"
      }
    }
  },
  "request": {
    "kind": "skillrunner.sequence.v1",
    "sequence": {
      "steps": [
        {
          "id": "prepare",
          "skill_id": "update-topic-synthesis-prepare",
          "workspace": "new",
          "short_circuit": {
            "when": {
              "path": "status",
              "equals": "canceled"
            },
            "result": "step_output"
          }
        },
        {
          "id": "core",
          "skill_id": "topic-synthesis-core-enrichment",
          "workspace": "reuse-workflow"
        },
        {
          "id": "finalize",
          "skill_id": "topic-synthesis-finalize",
          "workspace": "reuse-workflow"
        }
      ]
    }
  },
  "execution": {
    "mode": "auto",
    "zoteroHostAccess": {
      "required": true
    },
    "skillrunner_mode": "auto",
    "timeout_ms": 1200000
  },
  "result": {
    "final_step_id": "finalize",
    "fetch": { "type": "result" },
    "expects": {
      "result_json": "result/final-output.candidate.json"
    }
  },
  "hooks": {
    "applyResult": "../hooks/applyTopicSynthesisResult.mjs"
  }
}
