{
  "id": "create-topic-synthesis",
  "label": "Create Topic Synthesis",
  "provider": "acp",
  "version": "0.2.0",
  "taskNameTemplate": "Create synthesis: {topic seed}",
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "parameters": {
    "topicSeed": {
      "type": "string",
      "title": "Topic Seed",
      "description": "Natural-language topic seed for a new synthesis topic."
    },
    "language": {
      "type": "string",
      "title": "Language",
      "description": "Output language, such as auto, zh-CN, or en-US.",
      "default": "auto"
    }
  },
  "request": {
    "kind": "skillrunner.sequence.v1",
    "sequence": {
      "steps": [
        {
          "id": "prepare",
          "skill_id": "create-topic-synthesis-prepare",
          "workspace": "new"
        },
        {
          "id": "core",
          "skill_id": "topic-synthesis-core-enrichment",
          "workspace": "reuse-workflow"
        },
        {
          "id": "finalize",
          "skill_id": "topic-synthesis-finalize",
          "workspace": "reuse-workflow"
        }
      ]
    }
  },
  "execution": {
    "mode": "auto",
    "zoteroHostAccess": {
      "required": true
    },
    "skillrunner_mode": "interactive",
    "timeout_ms": 1200000
  },
  "result": {
    "final_step_id": "finalize",
    "fetch": { "type": "result" },
    "expects": {
      "result_json": "result/final-output.candidate.json"
    }
  },
  "hooks": {
    "applyResult": "../hooks/applyTopicSynthesisResult.mjs"
  }
}
