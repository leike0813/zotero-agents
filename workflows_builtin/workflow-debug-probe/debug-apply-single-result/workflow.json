{
  "id": "debug-apply-single-result",
  "label": "Debug: Apply Single Result",
  "version": "0.1.0",
  "provider": "skillrunner",
  "debug_only": true,
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "request": {
    "kind": "skillrunner.job.v1"
  },
  "execution": {
    "skillrunner_mode": "auto",
    "feedback": {
      "showNotifications": true
    },
    "timeout_ms": 180000
  },
  "result": {
    "fetch": { "type": "result" }
  },
  "hooks": {
    "buildRequest": "../hooks/buildDebugApplyContractRequest.mjs",
    "applyResult": "../hooks/applyDebugApplyContractResult.mjs"
  }
}

