{
  "id": "debug-apply-sequence-bundle",
  "label": "Debug: Apply Sequence Bundle",
  "version": "0.1.0",
  "provider": "skillrunner",
  "debug_only": true,
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "request": {
    "kind": "skillrunner.sequence.v1",
    "sequence": {
      "steps": [
        {
          "id": "bundle_one",
          "skill_id": "debug-apply-bundle-probe",
          "mode": "auto",
          "workspace": "new",
          "fetch_type": "bundle"
        },
        {
          "id": "bundle_two",
          "skill_id": "debug-apply-bundle-probe",
          "mode": "auto",
          "workspace": "reuse-workflow",
          "fetch_type": "bundle"
        }
      ]
    }
  },
  "execution": {
    "feedback": {
      "showNotifications": true
    }
  },
  "hooks": {
    "buildRequest": "../hooks/buildDebugApplyContractRequest.mjs",
    "applyResult": "../hooks/applyDebugApplyContractResult.mjs"
  }
}
