{
  "id": "debug-interactive-then-result",
  "label": "Debug: Interactive Then Result",
  "version": "0.1.0",
  "provider": "skillrunner",
  "debug_only": true,
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "request": {
    "kind": "skillrunner.sequence.v1",
    "sequence": {
      "steps": [
        {
          "id": "interactive",
          "skill_id": "debug-interactive-choice-probe",
          "mode": "interactive",
          "workspace": "new",
          "fetch_type": "result"
        },
        {
          "id": "result",
          "skill_id": "debug-apply-result-probe",
          "mode": "auto",
          "workspace": "reuse-workflow",
          "fetch_type": "result"
        }
      ]
    }
  },
  "execution": {
    "feedback": {
      "showNotifications": true
    },
    "timeout_ms": 300000
  },
  "hooks": {
    "buildRequest": "../hooks/buildDebugApplyContractRequest.mjs",
    "applyResult": "../hooks/applyDebugApplyContractResult.mjs"
  }
}
