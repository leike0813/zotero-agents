{
  "id": "debug-apply-result-then-bundle",
  "label": "Debug: Apply Result Then Bundle",
  "version": "0.1.0",
  "provider": "skillrunner",
  "debug_only": true,
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "parameters": {
    "skip_result_step": {
      "type": "boolean",
      "title": "Skip result step",
      "default": false
    }
  },
  "request": {
    "kind": "skillrunner.sequence.v1",
    "sequence": {
      "steps": [
        {
          "id": "result",
          "skill_id": "debug-apply-result-probe",
          "mode": "auto",
          "workspace": "new",
          "fetch_type": "result",
          "apply_result": {
            "workflow_id": "debug-apply-result-then-bundle",
            "on_failure": "fail_sequence"
          },
          "include_if": {
            "kind": "parameter",
            "parameter": "skip_result_step",
            "equals": false
          }
        },
        {
          "id": "bundle",
          "skill_id": "debug-apply-bundle-probe",
          "mode": "auto",
          "fetch_type": "bundle",
          "apply_result": {
            "workflow_id": "debug-apply-result-then-bundle",
            "on_failure": "fail_sequence"
          }
        }
      ]
    }
  },
  "execution": {
    "feedback": {
      "showNotifications": true
    }
  },
  "hooks": {
    "buildRequest": "../hooks/buildDebugApplyContractRequest.mjs",
    "applyResult": "../hooks/applyDebugApplyContractResult.mjs"
  }
}
