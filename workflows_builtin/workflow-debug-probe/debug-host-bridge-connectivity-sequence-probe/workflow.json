{
  "id": "debug-host-bridge-connectivity-sequence-probe",
  "label": "Debug: Host Bridge Connectivity Sequence Probe",
  "version": "0.1.0",
  "provider": "skillrunner",
  "debug_only": true,
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "parameters": {
    "probeDepth": {
      "type": "string",
      "title": "Probe Depth",
      "default": "capability",
      "enum": ["basic", "auth", "capability"]
    },
    "expectedConnectionMode": {
      "type": "string",
      "title": "Expected Connection Mode",
      "default": "auto",
      "enum": ["auto", "local", "remote"]
    }
  },
  "execution": {
    "zoteroHostAccess": {
      "required": true
    },
    "feedback": {
      "showNotifications": true
    }
  },
  "result": {
    "final_step_id": "probe"
  },
  "request": {
    "kind": "skillrunner.sequence.v1",
    "sequence": {
      "steps": [
        {
          "id": "probe",
          "skill_id": "debug-host-bridge-connectivity-probe",
          "mode": "auto",
          "workspace": "new",
          "fetch_type": "result"
        }
      ]
    }
  },
  "hooks": {
    "applyResult": "../hooks/applyHostBridgeConnectivityProbeResult.mjs"
  }
}
