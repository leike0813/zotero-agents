{
  "id": "add-digest-representative-image",
  "label": "Add Digest Representative Image",
  "version": "1.0.0",
  "provider": "pass-through",
  "debug_only": true,
  "inputs": {
    "unit": "workflow"
  },
  "validateSelection": {
    "select": {
      "policy": "digest-representative-image"
    },
    "derive": ["digestRepresentativeImageTarget"]
  },
  "parameters": {
    "markdown_src": {
      "type": "string",
      "title": "Markdown Image Source",
      "description": "Relative image path from the source Markdown file, for example figures/overview.jpg.",
      "default": ""
    }
  },
  "hooks": {
    "buildRequest": "hooks/buildRequest.mjs",
    "applyResult": "hooks/applyResult.mjs"
  }
}
