{
  "id": "literature-search-ingest",
  "label": "Literature Search Ingest",
  "provider": "skillrunner",
  "version": "0.1.0",
  "display": {
    "core": true,
    "emoji": "🔎"
  },
  "taskNameTemplate": "Search and ingest literature: {query}",
  "trigger": {
    "requiresSelection": false
  },
  "inputs": {
    "unit": "workflow"
  },
  "parameters": {
    "query": {
      "type": "string",
      "title": "Search Query",
      "description": "Free-form literature search topic, research direction, paper title, DOI, arXiv, PMID, or related seed."
    },
    "searchMode": {
      "type": "string",
      "title": "Search Mode",
      "description": "Choose auto mode detection, topic expansion, paper seed expansion, or exact targeted ingest.",
      "default": "auto",
      "enum": [
        "auto",
        "topic_expansion",
        "paper_seed_expansion",
        "targeted_ingest"
      ]
    },
    "targetCollection": {
      "type": "string",
      "title": "Target Collection",
      "description": "Optional Zotero collection for created or existing items.",
      "default": "",
      "allowCustom": false,
      "optionsSource": {
        "kind": "zotero.collections",
        "library": "current",
        "includeEmpty": true,
        "valueFormat": "collectionRef",
        "labelFormat": "path"
      }
    }
  },
  "request": {
    "kind": "skillrunner.job.v1",
    "create": {
      "skill_id": "literature-search-ingest",
      "mode": "interactive"
    }
  },
  "execution": {
    "zoteroHostAccess": {
      "required": true,
      "allowWriteApprovalBypass": true
    }
  },
  "result": {
    "fetch": { "type": "result" },
    "expects": {
      "result_json": "result/result.json"
    }
  },
  "hooks": {
    "applyResult": "hooks/applyResult.mjs"
  }
}
