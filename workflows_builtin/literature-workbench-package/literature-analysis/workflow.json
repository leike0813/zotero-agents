{
  "id": "literature-analysis",
  "label": "Literature Analysis",
  "provider": "skillrunner",
  "version": "0.1.0",
  "display": {
    "core": true,
    "emoji": "📊"
  },
  "inputs": {
    "unit": "attachment",
    "accepts": {
      "mime": [
        "text/markdown",
        "text/x-markdown",
        "text/plain",
        "application/pdf"
      ]
    },
    "per_parent": {
      "min": 1,
      "max": 1
    }
  },
  "validateSelection": {
    "select": {
      "policy": "literature-source"
    },
    "exclude": [
      {
        "kind": "generated-notes-all",
        "noteKinds": ["digest", "references", "citation-analysis"]
      }
    ]
  },
  "request": {
    "kind": "skillrunner.sequence.v1",
    "sequence": {
      "steps": [
        {
          "id": "digest",
          "skill_id": "literature-analysis",
          "mode": "auto",
          "workspace": "new",
          "fetch_type": "bundle",
          "apply_result": {
            "workflow_id": "literature-analysis",
            "on_failure": "continue"
          }
        },
        {
          "id": "tag-regulator",
          "skill_id": "tag-regulator",
          "mode": "auto",
          "workspace": "reuse-workflow",
          "fetch_type": "result",
          "apply_result": {
            "workflow_id": "tag-regulator",
            "on_failure": "continue"
          },
          "handoff": {
            "bindings": [
              {
                "kind": "file",
                "step": "digest",
                "source": "digest_path",
                "target": "/input/digest_markdown",
                "required": true
              }
            ]
          },
          "include_if": {
            "kind": "parameter",
            "parameter": "auto_tag_regulator",
            "equals": true
          }
        }
      ]
    }
  },
  "parameters": {
    "language": {
      "type": "string",
      "title": "Language",
      "enum": [
        "zh-CN",
        "en-US",
        "ja-JP",
        "ko-KR",
        "de-DE",
        "fr-FR",
        "es-ES",
        "ru-RU"
      ],
      "allowCustom": true,
      "default": "zh-CN"
    },
    "auto_tag_regulator": {
      "type": "boolean",
      "title": "Auto Tag Regulator",
      "default": true
    },
    "auto_tag_infer_tag": {
      "type": "boolean",
      "title": "Infer tags",
      "default": true,
      "visible_if": {
        "parameter": "auto_tag_regulator",
        "equals": true
      }
    }
  },
  "execution": {
    "poll_interval_ms": 2000
  },
  "result": {
    "fetch": { "type": "bundle" },
    "expects": {
      "result_json": "result/result.json",
      "artifacts": [
        "artifacts/digest.md",
        "artifacts/references.json",
        "artifacts/citation_analysis.json"
      ]
    }
  },
  "hooks": {
    "buildRequest": "hooks/buildRequest.mjs",
    "applyResult": "hooks/applyResult.mjs"
  }
}
