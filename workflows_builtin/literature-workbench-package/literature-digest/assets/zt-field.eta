<%
function escYaml(v) {
  var s = (v === null || v === undefined) ? "" : String(v);
  s = s.replace(/\\/g, "\\\\");
  s = s.replace(/"/g, '\\"');
  s = s.replace(/\r?\n/g, " ");
  return s.trim();
}

function getAttr(tag, name) {
  var re = new RegExp(name + '="([^"]*)"', "i");
  var m = re.exec(tag || "");
  return m ? m[1] : "";
}

function findPayloadTag(raw, payloadKind) {
  var re = /<span\b[^>]*>/gi;
  var m;
  while ((m = re.exec(raw || "")) !== null) {
    var tag = m[0];
    var block = getAttr(tag, "data-zs-block");
    var kind = getAttr(tag, "data-zs-payload");
    var val = getAttr(tag, "data-zs-value");
    if (block === "payload" && kind === payloadKind && val) {
      return tag;
    }
  }
  return "";
}

function payloadTypeOf(record) {
  return String(
    (record && (record.payloadType || record.payload_type || record.type)) ||
    (record && record.payload && record.payload.payloadType) ||
    (record && record.envelope && record.envelope.payloadType) ||
    ""
  ).trim();
}

function payloadObjectOf(record) {
  if (!record || typeof record !== "object") return null;
  if (record.payload && typeof record.payload === "object") return record.payload;
  if (record.envelope && record.envelope.payload && typeof record.envelope.payload === "object") {
    return record.envelope.payload;
  }
  if (record.markdown || record.content) {
    return {
      version: 1,
      entry: record.entry || record.payloadEntry || "",
      format: record.format || record.payloadFormat || "markdown",
      content: String(record.markdown || record.content || ""),
    };
  }
  return null;
}

function collectResolvedPayloadRecordsFromNote(note) {
  var records = [];
  var buckets = [
    note && note.payloadBlocks,
    note && note.payloads,
    note && note.embeddedPayloads,
    note && note.notePayloads,
    note && note.artifacts,
  ];
  for (var i = 0; i < buckets.length; i++) {
    var bucket = buckets[i];
    if (!bucket) continue;
    if (Object.prototype.toString.call(bucket) === "[object Array]") {
      for (var j = 0; j < bucket.length; j++) records.push(bucket[j]);
      continue;
    }
    if (typeof bucket === "object") {
      var keys = Object.keys(bucket);
      for (var k = 0; k < keys.length; k++) {
        var key = keys[k];
        var entry = bucket[key];
        if (entry && typeof entry === "object" && !payloadTypeOf(entry)) {
          records.push(Object.assign({ payloadType: key }, entry));
        } else {
          records.push(entry);
        }
      }
    }
  }
  return records;
}

function resolvedPayloadJsonFromNote(note, payloadKind) {
  var records = collectResolvedPayloadRecordsFromNote(note);
  for (var i = 0; i < records.length; i++) {
    var record = records[i];
    if (payloadTypeOf(record) !== payloadKind) continue;
    var payload = payloadObjectOf(record);
    if (payload) return payload;
  }
  return null;
}

function b64ToUtf8(b64) {
  if (!b64) return "";
  try {
    if (typeof atob === "function") {
      var bin = atob(b64);
      try {
        return decodeURIComponent(escape(bin));
      } catch (e1) {
        return bin;
      }
    }
  } catch (e2) {}

  try {
    if (typeof Buffer !== "undefined") {
      return Buffer.from(b64, "base64").toString("utf8");
    }
  } catch (e3) {}

  return "";
}

function readPayloadJson(payloadKind) {
  var notes = (it && it.notes) ? it.notes : [];
  for (var i = 0; i < notes.length; i++) {
    var resolved = resolvedPayloadJsonFromNote(notes[i], payloadKind);
    if (resolved) return resolved;

    var raw = notes[i] && notes[i].note ? String(notes[i].note) : "";
    var tag = findPayloadTag(raw, payloadKind);
    if (!tag) continue;

    var b64 = getAttr(tag, "data-zs-value");
    if (!b64) continue;

    var txt = b64ToUtf8(b64);
    if (!txt) continue;

    try {
      return JSON.parse(txt);
    } catch (e) {}
  }
  return null;
}

function resolveSource(r) {
  var candidates = [
    r && r.publicationTitle,
    r && r.conferenceName,
    r && r.university,
    r && r.archiveID,
  ];
  for (var i = 0; i < candidates.length; i++) {
    var value = String(candidates[i] === undefined || candidates[i] === null ? "" : candidates[i]).trim();
    if (value) return value;
  }
  return "";
}

function renderLocator(r) {
  var volume = String(r && r.volume !== undefined && r.volume !== null ? r.volume : "").trim();
  var issue = String(r && r.issue !== undefined && r.issue !== null ? r.issue : "").trim();
  var pages = String(r && r.pages !== undefined && r.pages !== null ? r.pages : "").trim();
  var place = String(r && r.place !== undefined && r.place !== null ? r.place : "").trim();
  var parts = [];
  if (volume) parts.push("Vol. " + volume);
  if (issue) parts.push("No. " + issue);
  if (pages) parts.push("pp. " + pages);
  if (place) parts.push(place);
  return parts.join("; ");
}

var refsPayload = readPayloadJson("references-json");
var refs = (refsPayload &&
  refsPayload.references &&
  Object.prototype.toString.call(refsPayload.references) === "[object Array]")
  ? refsPayload.references
  : [];

var title = (it && it.title) ? it.title : "";
var citekey = (it && it.citekey) ? it.citekey : "";

var lines = [];
lines.push('title: "' + escYaml(title) + '"');
lines.push('citekey: "' + escYaml(citekey) + '"');
lines.push("references_count: " + String(refs.length));

if (!refs.length) {
  lines.push("references: []");
} else {
  lines.push("references:");
  for (var j = 0; j < refs.length; j++) {
    var r = refs[j] || {};

    var year = (r.year === undefined || r.year === null) ? "" : String(r.year);
    var t = (r.title === undefined || r.title === null) ? "" : String(r.title);

    var authors = "";
    if (Object.prototype.toString.call(r.author) === "[object Array]") {
      authors = r.author.join("; ");
    } else if (r.author !== undefined && r.author !== null) {
      authors = String(r.author);
    }
    var source = resolveSource(r);
    var locator = renderLocator(r);

    var row = "";
    if (year) row += year + " | ";
    row += t;
    if (authors) row += " | " + authors;
    if (source) row += " | " + source;
    if (locator) row += " | " + locator;

    lines.push('  - "' + escYaml(row) + '"');
  }
}

var output = lines.join("\n");
%>
<%~ output %>
