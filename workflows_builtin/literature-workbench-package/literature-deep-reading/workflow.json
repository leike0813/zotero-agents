{
  "id": "literature-deep-reading",
  "label": "Literature Deep Reading",
  "provider": "skillrunner",
  "version": "0.1.0",
  "display": {
    "core": true,
    "emoji": "📖"
  },
  "inputs": {
    "unit": "attachment",
    "accepts": {
      "mime": [
        "text/markdown",
        "text/x-markdown",
        "text/plain",
        "application/pdf"
      ]
    },
    "per_parent": {
      "min": 1,
      "max": 1
    }
  },
  "validateSelection": {
    "select": {
      "policy": "literature-source"
    },
    "exclude": [
      {
        "kind": "artifact-exists",
        "target": "deep-reading-html"
      }
    ]
  },
  "request": {
    "kind": "skillrunner.sequence.v1",
    "sequence": {
      "steps": [
        {
          "id": "translate",
          "skill_id": "literature-translator",
          "mode": "auto",
          "workspace": "new",
          "fetch_type": "bundle",
          "apply_result": {
            "workflow_id": "literature-translator",
            "on_failure": "continue"
          },
          "include_if": {
            "kind": "runtime",
            "condition": "translator_alignment_missing"
          }
        },
        {
          "id": "deep_reading",
          "skill_id": "literature-deep-reading",
          "mode": "auto",
          "workspace": "reuse-workflow",
          "fetch_type": "bundle",
          "apply_result": {
            "workflow_id": "literature-deep-reading",
            "on_failure": "continue"
          },
          "handoff": {
            "bindings": [
              {
                "kind": "value",
                "step": "translate",
                "source": "alignment_path",
                "target": "/input/translator_alignment_path",
                "required": false
              },
              {
                "kind": "value",
                "step": "translate",
                "source": "output_path",
                "target": "/input/translator_output_path",
                "required": false
              },
              {
                "kind": "value",
                "step": "translate",
                "source": "status",
                "target": "/input/translator_status",
                "required": false
              }
            ]
          }
        }
      ]
    }
  },
  "parameters": {
    "target_language": {
      "type": "string",
      "title": "Target Language",
      "enum": [
        "zh-CN",
        "en-US",
        "ja-JP",
        "ko-KR",
        "de-DE",
        "fr-FR",
        "es-ES",
        "ru-RU"
      ],
      "allowCustom": true,
      "default": "zh-CN"
    },
    "mode": {
      "type": "string",
      "title": "Translation Mode",
      "enum": ["fast", "high_quality"],
      "default": "fast"
    }
  },
  "execution": {
    "poll_interval_ms": 2000,
    "timeout_ms": 1800000,
    "zoteroHostAccess": {
      "required": true
    }
  },
  "result": {
    "final_step_id": "deep_reading",
    "fetch": { "type": "bundle" },
    "expects": {
      "result_json": "literature-deep-reading.result.json",
      "artifacts": [
        "result/deep-reading.html",
        "result/deep-reading-manifest.json"
      ]
    }
  },
  "hooks": {
    "buildRequest": "hooks/buildRequest.mjs",
    "applyResult": "hooks/applyResult.mjs"
  }
}
