{
  "id": "literature-deep-reading",
  "label": "Literature Deep Reading",
  "provider": "skillrunner",
  "version": "0.1.0",
  "display": {
    "core": true,
    "emoji": "📖"
  },
  "inputs": {
    "unit": "attachment",
    "accepts": {
      "mime": [
        "text/markdown",
        "text/x-markdown",
        "text/plain",
        "application/pdf"
      ]
    },
    "per_parent": {
      "min": 1,
      "max": 1
    }
  },
  "validateSelection": {
    "select": {
      "policy": "literature-source"
    },
    "exclude": [
      {
        "kind": "artifact-exists",
        "target": "deep-reading-html"
      }
    ]
  },
  "request": {
    "kind": "skillrunner.sequence.v1"
  },
  "parameters": {
    "target_language": {
      "type": "string",
      "title": "Target Language",
      "enum": [
        "zh-CN",
        "en-US",
        "ja-JP",
        "ko-KR",
        "de-DE",
        "fr-FR",
        "es-ES",
        "ru-RU"
      ],
      "allowCustom": true,
      "default": "zh-CN"
    },
    "mode": {
      "type": "string",
      "title": "Translation Mode",
      "enum": ["fast", "high_quality"],
      "default": "fast"
    }
  },
  "execution": {
    "poll_interval_ms": 2000,
    "timeout_ms": 1800000,
    "zoteroHostAccess": {
      "required": true
    }
  },
  "result": {
    "final_step_id": "deep_reading",
    "fetch": { "type": "bundle" },
    "expects": {
      "result_json": "literature-deep-reading.result.json",
      "artifacts": [
        "result/deep-reading.html",
        "result/deep-reading-manifest.json"
      ]
    }
  },
  "hooks": {
    "buildRequest": "hooks/buildRequest.mjs",
    "applyResult": "hooks/applyResult.mjs"
  }
}
